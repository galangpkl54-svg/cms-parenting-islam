<% const safeFaqItems = Array.isArray(faqItems) ? faqItems : []; %>
<% const publishedDate = publishedAt ? new Date(publishedAt) : new Date(post.createdAt); %>
<% const modifiedDate = new Date(post.updatedAt); %>
<% const formattedDate = publishedDate.toLocaleDateString("id-ID", {
  day: "numeric",
  month: "long",
  year: "numeric"
}); %>
<% const authorName = post.author?.name || "Editor"; %>
<% const authorInitials = authorName
  .split(" ")
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part.charAt(0))
  .join("")
  .toUpperCase() || "E"; %>
<% const shareUrl = typeof meta !== "undefined" && meta && meta.canonical ? meta.canonical : `/posts/${post.slug}`; %>
<% const shareTitle = post.seoTitle || post.title; %>
<% const shareText = post.seoDescription || post.subheadline || post.excerpt || post.title; %>
<% const shareEncodedUrl = encodeURIComponent(shareUrl); %>
<% const shareEncodedTitle = encodeURIComponent(shareTitle); %>
<% const shareEncodedText = encodeURIComponent(shareText); %>
<% const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: post.seoDescription || post.subheadline || post.excerpt || post.title,
  datePublished: publishedDate.toISOString(),
  dateModified: modifiedDate.toISOString(),
  author: {
    "@type": "Person",
    name: authorName
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": meta && meta.canonical ? meta.canonical : `/posts/${post.slug}`
  }
}; %>
<% if (featuredImageUrl || bannerImageUrl) { articleSchema.image = [featuredImageUrl || bannerImageUrl]; } %>
<% if (safeFaqItems.length) { %>
  <% const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: safeFaqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }; %>
  <script type="application/ld+json"><%- JSON.stringify(faqSchema).replace(/</g, "\\u003c") %></script>
<% } %>
<script type="application/ld+json"><%- JSON.stringify(articleSchema).replace(/</g, "\\u003c") %></script>

<% const youtubePosition = post.youtubePosition || "TOP"; %>
<% const youtubeLabel = post.youtubeLabel || (typeof defaultYoutubeLabel !== "undefined" ? defaultYoutubeLabel : "Video Pendukung"); %>
<% const youtubeEnabled = youtubePreview && youtubePreview.embedUrl; %>
<% const bannerItemsValue = typeof bannerItems !== "undefined" && Array.isArray(bannerItems) ? bannerItems : []; %>
<% const legacyBannerItems = post.bannerImage
  ? [{
      image: post.bannerImage,
      url: post.bannerUrl || "",
      position: post.bannerPosition || "TOP"
    }]
  : []; %>
<% const normalizedBannerItems = (bannerItemsValue.length ? bannerItemsValue : legacyBannerItems)
  .map((item) => {
    if (!item || typeof item !== "object") {
      return null;
    }

    const image = typeof item.image === "string" ? item.image.trim() : "";
    if (!image) {
      return null;
    }

    const imageUrl = typeof item.imageUrl === "string" ? item.imageUrl.trim() : "";
    const url = typeof item.url === "string" ? item.url.trim() : "";
    const position = item.position === "LEFT" || item.position === "RIGHT" ? "RIGHT" : "TOP";

    return {
      image,
      ...(imageUrl ? { imageUrl } : {}),
      ...(url ? { url } : {}),
      position
    };
  })
  .filter(Boolean); %>
<% const topBannerItems = normalizedBannerItems.filter((item) => item.position === "TOP"); %>
<% const rightBannerItems = normalizedBannerItems.filter((item) => item.position === "RIGHT"); %>
<% function renderYoutubeBlock() { %>
  <% if (youtubeEnabled) { %>
    <section class="wp-panel overflow-hidden">
      <div class="border-b border-[color:var(--wp-border)] px-6 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.32em] text-brand-600"><%= youtubeLabel %></p>
      </div>
      <div class="aspect-video bg-slate-950">
        <iframe
          src="<%= youtubePreview.embedUrl %>?rel=0&modestbranding=1&playsinline=1"
          title="<%= post.title %> video"
          class="h-full w-full"
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </section>
  <% } %>
<% } %>

<% function renderBannerBlock(item, index) { %>
  <% if (item) { %>
    <% const bannerExternal = /^https?:\/\//i.test(item.url || ""); %>
    <% const bannerPlacement = item.position === "RIGHT" ? "side" : "top"; %>
    <% const bannerAspectClass = bannerPlacement === "top" ? "aspect-[4/1] sm:aspect-[6/1] lg:aspect-[8/1]" : "aspect-[5/4]"; %>
    <section class="wp-panel overflow-hidden">
      <% if (item.url) { %>
        <a href="<%= item.url %>" <%= bannerExternal ? 'target="_blank" rel="noopener noreferrer"' : '' %> class="block bg-[color:var(--wp-surface-2)]">
          <div class="<%= bannerAspectClass %> w-full overflow-hidden">
            <img src="<%= item.imageUrl || item.image %>" alt="<%= post.title %> banner <%= index + 1 %>" class="h-full w-full object-cover" loading="lazy" />
          </div>
        </a>
      <% } else { %>
        <div class="block bg-[color:var(--wp-surface-2)]">
          <div class="<%= bannerAspectClass %> w-full overflow-hidden">
            <img src="<%= item.imageUrl || item.image %>" alt="<%= post.title %> banner <%= index + 1 %>" class="h-full w-full object-cover" loading="lazy" />
          </div>
        </div>
      <% } %>
    </section>
  <% } %>
<% } %>

<article class="space-y-8">
  <% if (topBannerItems.length) { %>
    <div class="space-y-4">
      <% topBannerItems.forEach((item, index) => { %>
        <% renderBannerBlock(item, index); %>
      <% }) %>
    </div>
  <% } %>

  <header class="blog-article-hero wp-panel-strong">
    <div class="space-y-6 p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.34em] text-brand-600">
        <span>Artikel</span>
        <% if (typeof isPreview !== "undefined" && isPreview) { %>
          <span class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-[0.65rem] text-amber-700 dark:border-amber-500/30 dark:bg-amber-500/10 dark:text-amber-100">Preview</span>
        <% } %>
      </div>

      <div class="max-w-4xl">
        <h1 class="blog-article-title"><%= post.title %></h1>
        <% if (post.subheadline || post.excerpt) { %>
          <p class="blog-article-summary mt-4"><%= post.subheadline || post.excerpt %></p>
        <% } %>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <div class="flex items-center gap-3 rounded-full border border-[color:var(--wp-border)] bg-[color:var(--wp-surface)] px-3 py-2 shadow-sm">
          <div class="flex h-11 w-11 items-center justify-center overflow-hidden rounded-full bg-gradient-to-br from-brand-500 to-brand-700 text-sm font-semibold text-white">
            <% if (post.author?.avatar) { %>
              <img src="<%= post.author.avatar %>" alt="<%= authorName %>" class="h-full w-full object-cover" />
            <% } else { %>
              <span><%= authorInitials %></span>
            <% } %>
          </div>
          <div>
            <div class="text-sm font-semibold text-slate-950 dark:text-white">By <%= authorName %></div>
            <div class="text-xs text-slate-500 dark:text-slate-400"><%= formattedDate %></div>
          </div>
        </div>

        <div class="flex flex-wrap gap-2 text-sm text-slate-500 dark:text-slate-400">
          <span class="rounded-full border border-[color:var(--wp-border)] bg-[color:var(--wp-surface)] px-3 py-2"><%= post.readingTime %> min read</span>
          <span class="rounded-full border border-[color:var(--wp-border)] bg-[color:var(--wp-surface)] px-3 py-2"><%= post.viewCount %> views</span>
        </div>
      </div>
    </div>
  </header>

  <section class="grid gap-6 lg:grid-cols-[minmax(0,1.35fr)_minmax(260px,320px)] lg:items-start">
    <% if (post.featuredImage) { %>
      <img src="<%= featuredImageUrl || post.featuredImage %>" alt="<%= post.title %>" class="blog-article-frame max-h-[24rem] w-full object-cover" loading="eager" />
    <% } else { %>
      <div class="blog-article-frame border border-dashed border-[color:var(--wp-border)] bg-[color:var(--wp-surface)] px-6 py-10 text-sm text-slate-500 dark:text-slate-400">
        Featured image belum tersedia untuk artikel ini.
      </div>
    <% } %>

    <div class="space-y-6">
      <div class="blog-info-card wp-panel p-6">
        <p class="blog-eyebrow">Informasi</p>
        <dl class="blog-info-list mt-4 text-sm">
          <div>
            <dt class="text-slate-500 dark:text-slate-400">Published</dt>
            <dd class="font-medium text-slate-950 dark:text-white"><%= formattedDate %></dd>
          </div>
          <div>
            <dt class="text-slate-500 dark:text-slate-400">Reading time</dt>
            <dd class="font-medium text-slate-950 dark:text-white"><%= post.readingTime %> min</dd>
          </div>
          <div>
            <dt class="text-slate-500 dark:text-slate-400">Views</dt>
            <dd class="font-medium text-slate-950 dark:text-white"><%= post.viewCount %></dd>
          </div>
        </dl>
      </div>

      <div class="blog-info-card wp-panel p-6">
        <p class="blog-eyebrow">Quick Jump</p>
        <div class="mt-4 space-y-2">
          <a href="#comments" class="blog-anchor-link text-sm dark:text-slate-200">Lompat ke komentar</a>
          <% if (safeFaqItems.length) { %>
            <a href="#faq" class="blog-anchor-link text-sm dark:text-slate-200">Lompat ke FAQ</a>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <% if (youtubePosition === "TOP") { %>
    <div><% renderYoutubeBlock(); %></div>
  <% } %>

  <div class="grid gap-8 lg:grid-cols-[minmax(0,1.4fr)_minmax(320px,0.7fr)] lg:items-start">
    <div class="space-y-8">
      <section class="wp-panel p-8">
        <div class="article-content prose prose-lg max-w-none">
          <%- post.content %>
        </div>

        <% if (youtubePosition === "MIDDLE") { %>
          <div class="mt-8"><% renderYoutubeBlock(); %></div>
        <% } %>

        <div class="mt-8 flex flex-wrap gap-2">
          <% post.postCategories.forEach((item) => { %>
            <a href="/categories/<%= item.category.slug %>" class="wp-btn wp-btn-pill px-3 py-2 text-sm"><%= item.category.name %></a>
          <% }) %>
          <% post.postTags.forEach((item) => { %>
            <a href="/tags/<%= item.tag.slug %>" class="wp-btn wp-btn-pill px-3 py-2 text-sm"><%= item.tag.name %></a>
          <% }) %>
        </div>
      </section>

      <% if (safeFaqItems.length) { %>
        <section id="faq" class="blog-faq-card wp-panel p-8">
          <div class="flex flex-wrap items-end justify-between gap-3">
            <div>
              <p class="blog-eyebrow">Pertanyaan umum</p>
              <h2 class="mt-2 blog-section-title text-[2.6rem]">Pertanyaan yang sering ditanyakan</h2>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400">Accordion responsif agar pembaca cepat menemukan jawaban.</p>
          </div>

          <div class="mt-6 space-y-3">
            <% safeFaqItems.forEach((item, index) => { %>
              <details class="faq-item group rounded-2xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] p-5 transition-all duration-200 hover:shadow-md" <%= index === 0 ? "open" : "" %>>
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold text-slate-950 dark:text-white">
                  <span><%= item.question %></span>
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[color:var(--wp-border)] bg-[color:var(--wp-surface)] text-xl text-brand-600 transition-transform duration-200 group-open:rotate-45">+</span>
                </summary>
                <div class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-300"><%= item.answer %></div>
              </details>
            <% }) %>
          </div>
        </section>
      <% } %>

      <section class="wp-panel p-8">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="blog-eyebrow">Artikel terkait</p>
            <h2 class="mt-2 blog-section-title text-[2.4rem]">Baca lanjutan</h2>
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">Rekomendasi artikel yang masih relevan.</p>
        </div>

        <div class="blog-related-grid mt-6 md:grid-cols-2">
          <% if (related.length) { %>
            <% related.forEach((item) => { %>
              <a href="/posts/<%= item.slug %>" class="blog-related-card group p-5 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
                <div class="blog-eyebrow">Artikel terkait</div>
                <div class="blog-related-card__title mt-3 text-slate-950 transition-colors group-hover:text-brand-600 dark:text-white"><%= item.title %></div>
                <div class="mt-3 flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">
                  <span><%= item.readingTime %> min read</span>
                  <span><%= item.viewCount %> views</span>
                </div>
              </a>
            <% }) %>
          <% } else { %>
            <div class="rounded-2xl border border-dashed border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] p-5 text-sm text-slate-500 dark:text-slate-400">
              Belum ada artikel terkait yang cukup relevan.
            </div>
          <% } %>
        </div>
      </section>

      <% if (youtubePosition === "BOTTOM") { %>
        <div><% renderYoutubeBlock(); %></div>
      <% } %>

      <section id="comments" class="wp-panel p-8 scroll-mt-28">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="blog-eyebrow">Komentar</p>
            <h2 class="mt-2 blog-section-title text-[2.4rem]">Komentar pembaca</h2>
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">Komentar dimoderasi untuk mengurangi spam.</p>
        </div>

        <div class="blog-comment-form mt-6 rounded-2xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] p-5">
          <h3 class="text-lg font-semibold">Tinggalkan komentar</h3>
          <% if (commentStatus === "submitted") { %>
            <div class="mt-3 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-500/20 dark:bg-emerald-500/10 dark:text-emerald-100">
              Komentar Anda sudah diterima dan akan tampil setelah disetujui moderator.
            </div>
          <% } %>
          <% if (replyTarget) { %>
            <div class="mt-3 rounded-2xl border border-brand-200 bg-brand-50 px-4 py-3 text-sm text-brand-900 dark:border-brand-500/20 dark:bg-brand-500/10 dark:text-brand-100">
              Membalas <span class="font-semibold"><%= replyTarget.name %></span>
              <div class="mt-1 text-xs text-brand-700 dark:text-brand-100/80">Komentar ini akan tersimpan sebagai balasan.</div>
            </div>
          <% } %>

          <form class="mt-5 space-y-4" method="post" action="/comments">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="postId" value="<%= post.id %>" />
            <input type="hidden" name="parentId" value="<%= replyTo || '' %>" />
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label class="label" for="comment-name">Nama</label>
                <input class="input" id="comment-name" name="name" placeholder="Nama Anda" minlength="2" maxlength="100" required />
              </div>
              <div>
                <label class="label" for="comment-email">Email</label>
                <input class="input" id="comment-email" name="email" type="email" placeholder="email@contoh.com" maxlength="150" />
              </div>
            </div>

            <div>
              <label class="label" for="comment-content">Komentar</label>
              <textarea class="input min-h-36" id="comment-content" name="content" placeholder="Tulis komentar Anda..." minlength="3" maxlength="4000" required></textarea>
            </div>

            <div class="flex flex-wrap gap-2">
              <button class="wp-btn wp-btn-primary" type="submit">Kirim komentar</button>
              <% if (replyTarget) { %>
                <a class="wp-btn wp-btn-secondary" href="/posts/<%= post.slug %>#comments">Batal balas</a>
              <% } %>
            </div>
          </form>
        </div>

        <div class="blog-comment-thread mt-6">
          <% if (!commentTree.length) { %>
            <div class="rounded-2xl border border-dashed border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] p-6 text-sm text-slate-500 dark:text-slate-400">
              Belum ada komentar yang disetujui.
            </div>
          <% } %>

          <% function renderComment(comment, depth) { %>
            <div class="<%= depth > 0 ? 'ml-5 border-l border-[color:var(--wp-border)] pl-5' : '' %>">
              <article class="blog-comment-card comment-card rounded-2xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <div class="text-base font-semibold text-slate-950 dark:text-white"><%= comment.name %></div>
                    <div class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= new Date(comment.createdAt).toLocaleString("id-ID", {
                      day: "numeric",
                      month: "long",
                      year: "numeric",
                      hour: "2-digit",
                      minute: "2-digit"
                    }) %></div>
                  </div>
                  <a href="/posts/<%= post.slug %>?replyTo=<%= comment.id %>#comments" class="wp-btn wp-btn-pill px-3 py-2 text-xs">Reply</a>
                </div>
                <div class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-300"><%= comment.content %></div>
              </article>

              <% if (comment.children && comment.children.length) { %>
                <div class="mt-4 space-y-4">
                  <% comment.children.forEach((child) => { %>
                    <% renderComment(child, depth + 1); %>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% } %>

          <% commentTree.forEach((comment) => { %>
            <% renderComment(comment, 0); %>
          <% }) %>
        </div>
      </section>
    </div>

    <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
      <div class="blog-share-card wp-panel p-6" data-article-share data-share-url="<%= shareUrl %>" data-share-title="<%= shareTitle %>" data-share-text="<%= shareText %>">
        <p class="blog-eyebrow">Bagikan artikel</p>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Kirim artikel ke platform mana pun. Preview share tetap membawa thumbnail dari metadata halaman.</p>

        <div class="mt-4 flex flex-wrap gap-2">
          <button type="button" class="wp-btn wp-btn-primary flex-1" data-share-native>Bagikan via perangkat</button>
          <button type="button" class="wp-btn wp-btn-secondary flex-1" data-share-copy>Salin tautan</button>
        </div>
      </div>

      <% if (rightBannerItems.length) { %>
        <div class="space-y-4">
          <% rightBannerItems.forEach((item, index) => { %>
            <% renderBannerBlock(item, index); %>
          <% }) %>
        </div>
      <% } %>
    </aside>
  </div>
</article>
