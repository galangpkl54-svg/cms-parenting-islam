<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Manajemen Artikel · CMS Professional</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #f4f7fc;
    }

    .posts-container {
      max-width: 1440px;
      margin: 0 auto;
    }

    /* Header Premium dengan Ikon */
    .header-premium {
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      border-radius: 1.75rem;
      border: 1px solid rgba(0, 0, 0, 0.04);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.02);
      overflow: hidden;
      margin-bottom: 1.75rem;
    }

    .header-gradient {
      background: linear-gradient(120deg, #0f2b3d 0%, #1a5f7a 100%);
      padding: 2rem 2rem 1.75rem 2rem;
      position: relative;
      overflow: hidden;
    }

    .header-gradient::before {
      content: '';
      position: absolute;
      top: -30%;
      right: -10%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0) 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    /* Filter Bar Modern */
    .filter-glass {
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      padding: 1.25rem 2rem;
    }

    /* Card Grid untuk Posts */
    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .post-card {
      background: white;
      border-radius: 1.5rem;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
      border: 1px solid #eef2f8;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .post-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.12);
      border-color: #dce5ed;
    }

    .card-thumbnail {
      aspect-ratio: 16/9;
      background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
      overflow: hidden;
      position: relative;
    }

    .card-thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .post-card:hover .card-thumbnail img {
      transform: scale(1.03);
    }

    .thumbnail-placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      background: linear-gradient(135deg, #e2e8f0, #f1f5f9);
      color: #94a3b8;
      font-size: 2rem;
    }

    .card-content {
      padding: 1.25rem 1.5rem 1.5rem;
    }

    .post-title-card {
      font-size: 1.15rem;
      font-weight: 700;
      line-height: 1.4;
      margin-bottom: 0.5rem;
    }

    .post-title-card a {
      text-decoration: none;
      color: #0f172a;
      transition: color 0.2s;
    }

    .post-title-card a:hover {
      color: #1e6f9f;
    }

    .post-meta-card {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.7rem;
      color: #64748b;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #eef2f8;
    }

    .post-excerpt-card {
      font-size: 0.8rem;
      line-height: 1.5;
      color: #475569;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 1rem;
    }

    .card-stats {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
      font-size: 0.7rem;
      color: #64748b;
    }

    .badge-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 0.2rem 0.8rem;
      border-radius: 2rem;
      font-size: 0.65rem;
      font-weight: 700;
    }

    .category-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .category-pill {
      font-size: 0.6rem;
      padding: 0.25rem 0.7rem;
      background: #f1f5f9;
      border-radius: 2rem;
      color: #475569;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .action-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .btn-action {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.45rem 0.75rem;
      font-size: 0.7rem;
      font-weight: 600;
      border-radius: 0.75rem;
      transition: all 0.2s;
      text-decoration: none;
      cursor: pointer;
      background: white;
      border: 1px solid #e2e8f0;
      color: #334155;
    }

    .btn-action:hover {
      transform: translateY(-1px);
    }

    .btn-primary-action {
      background: #0f3b5c;
      border-color: #0f3b5c;
      color: white;
    }

    .btn-primary-action:hover {
      background: #1a5a7a;
    }

    .btn-success-action {
      background: #10b981;
      border-color: #10b981;
      color: white;
    }

    .btn-warning-action {
      background: #f59e0b;
      border-color: #f59e0b;
      color: white;
    }

    .btn-danger-action {
      background: #ef4444;
      border-color: #ef4444;
      color: white;
    }

    .btn-outline-action {
      background: transparent;
      border-color: #cbd5e1;
      color: #475569;
    }

    .btn-outline-action:hover {
      background: #f8fafc;
    }

    .empty-state {
      background: white;
      border-radius: 2rem;
      padding: 4rem 2rem;
      text-align: center;
    }

    .pagination-modern {
      display: flex;
      justify-content: center;
      margin-top: 2rem;
    }

    @media (max-width: 768px) {
      .posts-grid {
        grid-template-columns: 1fr;
      }

      .header-gradient {
        padding: 1.5rem;
      }

      .filter-glass {
        padding: 1rem;
      }
    }
  </style>
</head>

<body>
  <div class="posts-container">
    <% const statusLabelMap={ DRAFT: "Draft" , PUBLISHED: "Published" , ARCHIVED: "Archived" }; const statusClassMap={
      DRAFT: "bg-slate-100 text-slate-700 border-slate-200" ,
      PUBLISHED: "bg-emerald-50 text-emerald-700 border-emerald-200" ,
      ARCHIVED: "bg-amber-50 text-amber-700 border-amber-200" }; const statusIconMap={ DRAFT: "fa-pen-fancy" ,
      PUBLISHED: "fa-globe" , ARCHIVED: "fa-archive" }; %>

      <!-- HEADER PREMIUM dengan Ikon Dashboard Style -->
      <div class="header-premium">
        <div class="header-gradient">
          <div style="position: relative; z-index: 2;">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center backdrop-blur">
                <i class="fas fa-pen-ruler text-white text-lg"></i>
              </div>
              <div>
                <span
                  class="text-white/50 text-[0.65rem] font-semibold tracking-wider uppercase flex items-center gap-2">
                  <i class="fas fa-database text-[10px]"></i> Content Management
                </span>
              </div>
            </div>
            <h1 class="text-3xl font-bold text-white tracking-tight flex items-center gap-3">
              <i class="fas fa-newspaper text-white/80"></i> Posts
            </h1>
            <p class="text-white/70 text-sm mt-2 max-w-lg">
              <i class="fas fa-info-circle mr-1"></i> Kelola seluruh artikel, pantau performa konten, dan optimasi
              workflow editorial Anda.
            </p>
            <div class="mt-5 flex gap-3">
              <a href="/admin/posts/create"
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/15 backdrop-blur hover:bg-white/25 text-white text-sm font-semibold rounded-xl transition-all border border-white/20">
                <i class="fas fa-plus-circle"></i> Buat Artikel Baru
              </a>
            </div>
          </div>
        </div>

        <!-- Filter Bar Modern dengan Ikon -->
        <div class="filter-glass">
          <form method="get" action="/admin/posts"
            class="grid grid-cols-1 md:grid-cols-[1fr_200px_auto] gap-3 items-end">
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">
                <i class="fas fa-search mr-1"></i> Cari artikel
              </label>
              <input
                class="w-full rounded-xl border-slate-200 bg-white px-4 py-2.5 text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition"
                name="q" value="<%= q || '' %>" placeholder="Judul, slug, subheadline, atau excerpt..." />
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1">
                <i class="fas fa-filter mr-1"></i> Status
              </label>
              <select
                class="w-full rounded-xl border-slate-200 bg-white px-4 py-2.5 text-sm focus:ring-2 focus:ring-brand-500/20"
                name="status">
                <option value="ALL" <%=status==='ALL' ? 'selected' : '' %>>📋 Semua status</option>
                <option value="DRAFT" <%=status==='DRAFT' ? 'selected' : '' %>>✏️ Draft</option>
                <option value="PUBLISHED" <%=status==='PUBLISHED' ? 'selected' : '' %>>🌍 Published</option>
                <option value="ARCHIVED" <%=status==='ARCHIVED' ? 'selected' : '' %>>📦 Archived</option>
              </select>
            </div>
            <div class="flex gap-2 justify-start md:justify-end">
              <button type="submit"
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-800 hover:bg-slate-900 text-white text-sm font-medium rounded-xl transition">
                <i class="fas fa-sliders-h"></i> Terapkan
              </button>
              <% if (q || status !=='ALL' ) { %>
                <a href="/admin/posts"
                  class="inline-flex items-center gap-2 px-5 py-2.5 border border-slate-300 rounded-xl text-sm font-medium text-slate-700 hover:bg-slate-100 transition">
                  <i class="fas fa-times"></i> Reset
                </a>
                <% } %>
            </div>
          </form>
        </div>
      </div>

      <!-- POSTS GRID MODERN dengan Ikon Lengkap -->
      <% if (!posts.length) { %>
        <div class="empty-state">
          <div class="w-20 h-20 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-edit text-3xl text-slate-400"></i>
          </div>
          <h3 class="text-xl font-semibold text-slate-700 mb-2">Belum ada konten</h3>
          <p class="text-slate-500 mb-5">Mulai tulis artikel pertama Anda untuk dashboard ini.</p>
          <a href="/admin/posts/create"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-800 hover:bg-slate-900 text-white rounded-xl transition">
            <i class="fas fa-plus"></i> Buat Artikel
          </a>
        </div>
        <% } else { %>
          <div class="posts-grid">
            <% posts.forEach((post)=> {
              const statusLabel = statusLabelMap[post.status] || post.status;
              const statusClass = statusClassMap[post.status] || statusClassMap.DRAFT;
              const statusIcon = statusIconMap[post.status] || "fa-file";
              %>
              <article class="post-card">
                <div class="card-thumbnail">
                  <% if (post.featuredImage) { %>
                    <img src="<%= post.featuredImage %>" alt="<%= post.title %>" loading="lazy" />
                    <% } else { %>
                      <div class="thumbnail-placeholder">
                        <i class="fas fa-image"></i>
                        <span class="ml-2 text-xs">No image</span>
                      </div>
                      <% } %>
                </div>
                <div class="card-content">
                  <div class="post-meta-card">
                    <span><i class="far fa-user-circle"></i>
                      <%= post.author?.name || 'Admin' %>
                    </span>
                    <span><i class="far fa-calendar-alt"></i>
                      <%= new Date(post.updatedAt).toLocaleDateString("id-ID", { day: "numeric" , month: "short" ,
                        year: "numeric" }) %>
                    </span>
                    <span><i class="far fa-clock"></i>
                      <%= post.readingTime || '2' %> min read
                    </span>
                  </div>
                  <h2 class="post-title-card">
                    <a href="/admin/posts/<%= post.id %>/edit">
                      <i class="fas fa-link text-xs text-slate-400 mr-1"></i>
                      <%= post.title %>
                    </a>
                  </h2>
                  <% if (post.subheadline) { %>
                    <p class="post-excerpt-card">
                      <i class="fas fa-quote-left text-xs text-slate-400 mr-1"></i>
                      <%= post.subheadline %>
                    </p>
                    <% } else { %>
                      <p class="post-excerpt-card">
                        <%= (post.excerpt || (post.content ? post.content.replace(/<[^>]*>/g, '').slice(0, 100) : 'Tidak ada ringkasan')) %>...
                      </p>
                      <% } %>

                        <div class="category-pills">
                          <i class="fas fa-folder-tree text-xs text-slate-400 mr-1"></i>
                          <% (post.postCategories || []).slice(0, 3).forEach((item)=> { %>
                            <span class="category-pill">
                              <i class="fas fa-tag"></i>
                              <%= item.category.name %>
                            </span>
                            <% }) %>
                              <% if ((post.postCategories || []).length> 3) { %>
                                <span class="category-pill">+<%= post.postCategories.length - 3 %></span>
                                <% } %>
                                  <% if ((post.postCategories || []).length===0) { %>
                                    <span class="category-pill text-slate-400">—</span>
                                    <% } %>
                        </div>

                        <div class="card-stats">
                          <span><i class="fas fa-eye"></i>
                            <%= post.viewCount || 0 %> views
                          </span>
                          <span><i class="fas fa-comment"></i>
                            <%= post.commentCount || 0 %> komentar
                          </span>
                          <span class="badge-status <%= statusClass %> border">
                            <i class="fas <%= statusIcon %> text-[10px]"></i>
                            <%= statusLabel %>
                          </span>
                        </div>

                        <div class="action-buttons">
                          <a href="/admin/posts/<%= post.id %>/preview" class="btn-action btn-outline-action"
                            target="_blank">
                            <i class="fas fa-eye"></i> Preview
                          </a>
                          <% if (post.status !=='PUBLISHED' ) { %>
                            <form
                              action="/admin/posts/<%= post.id %>/publish?_method=PATCH"
                              method="post"
                              data-crud-form
                              data-confirm-title="Konfirmasi publikasi"
                              data-confirm-message="Apakah Anda yakin untuk mempublikasikan post ini?"
                              class="flex-1">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <button type="submit" class="btn-action btn-success-action w-full">
                                <i class="fas fa-check-circle"></i> Publish
                              </button>
                            </form>
                            <% } else { %>
                              <form
                                action="/admin/posts/<%= post.id %>/draft?_method=PATCH"
                                method="post"
                                data-crud-form
                                data-confirm-title="Konfirmasi draft"
                                data-confirm-message="Apakah Anda yakin untuk mengubah post ini menjadi draft?"
                                class="flex-1">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <button type="submit" class="btn-action btn-warning-action w-full">
                                  <i class="fas fa-pen-fancy"></i> Draft
                                </button>
                              </form>
                              <% } %>
                                <a href="/admin/posts/<%= post.id %>/edit" class="btn-action btn-primary-action">
                                  <i class="fas fa-edit"></i> Edit
                                </a>
                                <form
                                  action="/admin/posts/<%= post.id %>?_method=DELETE"
                                  method="post"
                                  data-crud-form
                                  data-confirm-title="Konfirmasi penghapusan"
                                  data-confirm-message="Apakah Anda yakin untuk menghapus post ini?"
                                  class="flex-1">
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                  <button type="submit" class="btn-action btn-danger-action w-full">
                                    <i class="fas fa-trash-alt"></i> Hapus
                                  </button>
                                </form>
                        </div>
                </div>
              </article>
              <% }) %>
          </div>
          <% } %>

            <!-- PAGINATION MODERN dengan Ikon -->
            <% if (typeof pagination !=='undefined' && pagination && pagination.totalPages> 1) { %>
              <div class="pagination-modern">
                <nav
                  class="inline-flex items-center gap-1.5 bg-white px-4 py-2 rounded-2xl border border-slate-200 shadow-sm">
                  <% if (pagination.hasPrev) { %>
                    <a href="?page=<%= pagination.prevPage %><%= q ? `&q=${encodeURIComponent(q)}` : '' %><%= status !== 'ALL' ? `&status=${status}` : '' %>"
                      class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:bg-slate-100 transition">
                      <i class="fas fa-chevron-left"></i>
                    </a>
                    <% } else { %>
                      <span
                        class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-300 cursor-not-allowed"><i
                          class="fas fa-chevron-left"></i></span>
                      <% } %>

                        <% let startPage=Math.max(1, pagination.currentPage - 2); let
                          endPage=Math.min(pagination.totalPages, pagination.currentPage + 2); if (endPage - startPage <
                          4) { if (startPage> 1) startPage = Math.max(1, endPage - 4);
                          if (endPage < pagination.totalPages) endPage=Math.min(pagination.totalPages, startPage + 4); }
                            for (let p=startPage; p <=endPage; p++) { %>
                            <% if (p===pagination.currentPage) { %>
                              <span
                                class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-800 text-white font-semibold shadow-sm">
                                <%= p %>
                              </span>
                              <% } else { %>
                                <a href="?page=<%= p %><%= q ? `&q=${encodeURIComponent(q)}` : '' %><%= status !== 'ALL' ? `&status=${status}` : '' %>"
                                  class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:bg-slate-100 transition">
                                  <%= p %>
                                </a>
                                <% } %>
                                  <% } %>

                                    <% if (pagination.hasNext) { %>
                                      <a href="?page=<%= pagination.nextPage %><%= q ? `&q=${encodeURIComponent(q)}` : '' %><%= status !== 'ALL' ? `&status=${status}` : '' %>"
                                        class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:bg-slate-100 transition">
                                        <i class="fas fa-chevron-right"></i>
                                      </a>
                                      <% } else { %>
                                        <span
                                          class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-300 cursor-not-allowed"><i
                                            class="fas fa-chevron-right"></i></span>
                                        <% } %>
                </nav>
              </div>
              <% } %>
  </div>

</body>

</html>
