<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Dashboard · CMS Professional</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #f4f7fc;
      color: #1a2c3e;
      line-height: 1.5;
      min-height: 100vh;
      padding: 1.5rem;
    }

    .dashboard-container {
      max-width: 1440px;
      margin: 0 auto;
    }

    /* Header Premium seperti halaman Posts */
    .header-premium {
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      border-radius: 1.75rem;
      border: 1px solid rgba(0, 0, 0, 0.04);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.02);
      overflow: hidden;
      margin-bottom: 1.75rem;
    }

    .header-gradient {
      background: linear-gradient(120deg, #0f2b3d 0%, #1a5f7a 100%);
      padding: 2rem 2rem 1.75rem 2rem;
      position: relative;
      overflow: hidden;
    }

    .header-gradient::before {
      content: '';
      position: absolute;
      top: -30%;
      right: -10%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0) 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    /* Stats Grid Premium */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-card-premium {
      background: white;
      border-radius: 1.5rem;
      padding: 1.5rem;
      transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
      border: 1px solid #eef2f8;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
      position: relative;
      overflow: hidden;
    }

    .stat-card-premium:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.12);
      border-color: #dce5ed;
    }

    .stat-icon-wrapper {
      width: 3rem;
      height: 3rem;
      background: linear-gradient(135deg, #eef2ff, #e0eaf5);
      border-radius: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
    }

    .stat-icon-wrapper i {
      font-size: 1.4rem;
      color: #1a5f7a;
    }

    .stat-label-premium {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #6b8aab;
    }

    .stat-value-premium {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #0a2b3e;
      margin: 0.25rem 0 0.5rem 0;
    }

    .stat-hint-premium {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: #f1f5f9;
      border-radius: 2rem;
      padding: 0.2rem 0.8rem;
      font-size: 0.65rem;
      font-weight: 500;
      color: #475569;
    }

    /* Two Column Grid */
    .two-column-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.75rem;
    }

    /* Modern Panel seperti Posts */
    .modern-panel-premium {
      background: white;
      border-radius: 1.5rem;
      border: 1px solid #eef2f8;
      overflow: hidden;
      transition: all 0.2s;
    }

    .panel-header-premium {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid #eff3f8;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #fefefe;
    }

    .panel-header-premium h3 {
      font-size: 1rem;
      font-weight: 700;
      color: #0f172a;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .panel-header-premium h3 i {
      color: #1a5f7a;
      font-size: 1.1rem;
    }

    .link-action-premium {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 1rem;
      background: #f1f5f9;
      border-radius: 2rem;
      font-size: 0.7rem;
      font-weight: 600;
      color: #1a5f7a;
      text-decoration: none;
      transition: all 0.2s;
    }

    .link-action-premium:hover {
      background: #e2e8f0;
      transform: translateX(2px);
    }

    /* List Items */
    .items-list-premium {
      padding: 0;
    }

    .list-item-premium {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid #f0f4fa;
      transition: background 0.2s;
    }

    .list-item-premium:last-child {
      border-bottom: none;
    }

    .list-item-premium:hover {
      background: #fafdff;
    }

    .item-row-premium {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .item-content {
      flex: 1;
    }

    .item-title-premium {
      font-weight: 700;
      font-size: 0.9rem;
      color: #0f172a;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.35rem;
    }

    .item-title-premium a {
      text-decoration: none;
      color: #0f172a;
      transition: color 0.2s;
    }

    .item-title-premium a:hover {
      color: #1a5f7a;
    }

    .badge-premium {
      font-size: 0.6rem;
      font-weight: 700;
      padding: 0.2rem 0.7rem;
      border-radius: 2rem;
      letter-spacing: 0.3px;
    }

    .badge-published {
      background: #e3f7ec;
      color: #1f7840;
    }

    .badge-draft {
      background: #fff1e0;
      color: #c97e0a;
    }

    .badge-approved {
      background: #e3f7ec;
      color: #1f7840;
    }

    .badge-pending {
      background: #fff1e0;
      color: #c97e0a;
    }

    .item-meta-premium {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.65rem;
      color: #8196ae;
      margin-top: 0.25rem;
    }

    .comment-content-premium {
      font-size: 0.75rem;
      color: #475569;
      margin-top: 0.5rem;
      line-height: 1.45;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .action-buttons-premium {
      display: flex;
      gap: 0.4rem;
      align-items: center;
    }

    .btn-icon-premium {
      width: 1.8rem;
      height: 1.8rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 0.6rem;
      background: #f1f5f9;
      color: #64748b;
      text-decoration: none;
      transition: all 0.2s;
      font-size: 0.7rem;
    }

    .btn-icon-premium:hover {
      background: #e2e8f0;
      color: #1a5f7a;
    }

    /* Empty State */
    .empty-state-premium {
      text-align: center;
      padding: 2.5rem 1.5rem;
      color: #94a3b8;
    }

    .empty-state-premium i {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
      opacity: 0.5;
    }

    /* Responsive */
    @media (max-width: 880px) {
      body {
        padding: 1rem;
      }

      .two-column-grid {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      .stats-grid {
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      }

      .header-gradient {
        padding: 1.5rem;
      }
    }
  </style>
</head>

<body>
  <div class="dashboard-container">
    <!-- HEADER PREMIUM (style seperti halaman Posts) -->
    <div class="header-premium">
      <div class="header-gradient">
        <div style="position: relative; z-index: 2;">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center backdrop-blur">
              <i class="fas fa-chalkboard-user text-white text-lg"></i>
            </div>
            <div>
              <span class="text-white/50 text-[0.65rem] font-semibold tracking-wider uppercase flex items-center gap-2">
                <i class="fas fa-chart-line text-[10px]"></i> Overview
              </span>
            </div>
          </div>
          <h1 class="text-3xl font-bold text-white tracking-tight flex items-center gap-3">
            <i class="fas fa-chart-pie text-white/80"></i> Dashboard
          </h1>
          <p class="text-white/70 text-sm mt-2 max-w-2xl">
            <i class="fas fa-info-circle mr-1"></i> Ringkasan konten, aktivitas terbaru, dan indikator moderasi untuk
            CMS Anda.
          </p>
          <div class="mt-4">
            <span
              class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 backdrop-blur rounded-full text-white/80 text-xs">
              <i class="fas fa-circle" style="font-size: 0.45rem; color: #10b981;"></i> Live overview
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- STATISTICS CARDS PREMIUM -->
    <div class="stats-grid">
      <% const statCards=[ { label: "Total Posts" , value: stats.posts, hint: "Semua artikel" , icon: "fa-newspaper" ,
        color: "#1a5f7a" }, { label: "Published" , value: stats.publishedPosts, hint: "Siap tayang" ,
        icon: "fa-check-circle" , color: "#10b981" }, { label: "Drafts" , value: stats.drafts, hint: "Masih dikerjakan"
        , icon: "fa-pen-fancy" , color: "#f59e0b" }, { label: "Comments" , value: stats.comments, hint: "Semua komentar"
        , icon: "fa-comments" , color: "#8b5cf6" }, { label: "Categories" , value: stats.categories,
        hint: "Taksonomi aktif" , icon: "fa-folder-tree" , color: "#06b6d4" }, { label: "Users" , value: stats.users,
        hint: "Akun admin" , icon: "fa-users" , color: "#ef4444" }, { label: "Views" , value: stats.views,
        hint: "Akumulasi view" , icon: "fa-chart-line" , color: "#3b82f6" }, { label: "Media" , value: stats.media,
        hint: "Asset library" , icon: "fa-images" , color: "#ec4899" }, { label: "Pending" , value:
        stats.pendingComments, hint: "Moderasi" , icon: "fa-clock" , color: "#f97316" } ]; %>
        <% statCards.forEach((card)=> { %>
          <div class="stat-card-premium">
            <div class="stat-icon-wrapper">
              <i class="fas <%= card.icon %>" style="color: <%= card.color %>;"></i>
            </div>
            <div class="stat-label-premium">
              <%= card.label %>
            </div>
            <div class="stat-value-premium">
              <%= card.value %>
            </div>
            <div>
              <span class="stat-hint-premium">
                <i class="far fa-lightbulb"></i>
                <%= card.hint %>
              </span>
            </div>
          </div>
          <% }) %>
    </div>

    <!-- 2 COLUMN: LATEST POSTS & LATEST COMMENTS -->
    <div class="two-column-grid">
      <!-- ARTIKEL TERBARU PANEL -->
      <div class="modern-panel-premium">
        <div class="panel-header-premium">
          <h3>
            <i class="fas fa-pen-ruler"></i>
            Artikel Terbaru
          </h3>
          <a href="/admin/posts" class="link-action-premium">
            <i class="fas fa-arrow-right"></i> Lihat semua
          </a>
        </div>
        <div class="items-list-premium">
          <% if (stats.latestPosts && stats.latestPosts.length) { %>
            <% stats.latestPosts.forEach((post)=> { %>
              <div class="list-item-premium">
                <div class="item-row-premium">
                  <div class="item-content">
                    <div class="item-title-premium">
                      <a href="/admin/posts/<%= post.id %>/edit">
                        <i class="fas fa-file-alt text-slate-400 text-xs mr-1"></i>
                        <%= post.title %>
                      </a>
                      <span
                        class="badge-premium <%= post.status === 'published' ? 'badge-published' : 'badge-draft' %>">
                        <%= post.status==='published' ? 'Terbit' : (post.status || 'Draft' ) %>
                      </span>
                    </div>
                    <div class="item-meta-premium">
                      <span><i class="far fa-user-circle"></i>
                        <%= post.author?.name || "Admin" %>
                      </span>
                      <span><i class="far fa-calendar-alt"></i>
                        <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('id-ID') : '-' %>
                      </span>
                      <span><i class="fas fa-eye"></i>
                        <%= post.viewCount || 0 %> views
                      </span>
                    </div>
                  </div>
                  <div class="action-buttons-premium">
                    <a href="/admin/posts/<%= post.id %>/preview" class="btn-icon-premium" title="Preview"
                      target="_blank">
                      <i class="fas fa-eye"></i>
                    </a>
                    <a href="/admin/posts/<%= post.id %>/edit" class="btn-icon-premium" title="Edit">
                      <i class="fas fa-edit"></i>
                    </a>
                  </div>
                </div>
              </div>
              <% }) %>
                <% } else { %>
                  <div class="empty-state-premium">
                    <i class="fas fa-inbox"></i>
                    <p class="text-sm">Belum ada artikel</p>
                  </div>
                  <% } %>
        </div>
      </div>

      <!-- KOMENTAR TERBARU PANEL -->
      <div class="modern-panel-premium">
        <div class="panel-header-premium">
          <h3>
            <i class="fas fa-message"></i>
            Komentar Terbaru
          </h3>
          <a href="/admin/comments" class="link-action-premium">
            <i class="fas fa-shield-alt"></i> Moderate
          </a>
        </div>
        <div class="items-list-premium">
          <% if (stats.latestComments && stats.latestComments.length) { %>
            <% stats.latestComments.forEach((comment)=> { %>
              <div class="list-item-premium">
                <div class="item-row-premium">
                  <div class="item-content">
                    <% const commentStatus = String(comment.status || '').toUpperCase(); %>
                    <div class="item-title-premium">
                      <i class="fas fa-user-circle text-slate-400 text-xs mr-1"></i>
                      <%= comment.name %>
                        <span
                          class="badge-premium <%= commentStatus === 'APPROVED' ? 'badge-published' : 'badge-pending' %>">
                          <%= commentStatus === 'APPROVED' ? 'Disetujui' : (comment.status || 'Menunggu' ) %>
                        </span>
                    </div>
                    <div class="item-meta-premium">
                      <span><i class="fas fa-book-open"></i>
                        <%= comment.post?.title || "Artikel tidak tersedia" %>
                      </span>
                    </div>
                    <div class="comment-content-premium">
                      "<%= comment.content && comment.content.length> 70 ? comment.content.slice(0, 70) + '…' :
                        comment.content %>"
                    </div>
                    <div class="item-meta-premium">
                      <span><i class="far fa-clock"></i>
                        <%= new Date(comment.createdAt).toLocaleString("id-ID", { day: "numeric" , month: "short" ,
                          year: "numeric" , hour: "2-digit" , minute: "2-digit" }) %>
                      </span>
                    </div>
                  </div>
                  <div class="action-buttons-premium">
                    <% if (commentStatus !== 'APPROVED' ) { %>
                      <form
                        action="/admin/comments/<%= comment.id %>?_method=PATCH"
                        method="post"
                        style="display: inline;"
                        data-crud-form
                        data-confirm-title="Konfirmasi persetujuan"
                        data-confirm-message="Apakah Anda yakin untuk menyetujui komentar ini?">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <input type="hidden" name="status" value="APPROVED" />
                        <button type="submit" class="btn-icon-premium" title="Setujui" style="color: #10b981;">
                          <i class="fas fa-check-circle"></i>
                        </button>
                      </form>
                      <% } %>
                      <a
                        href="/admin/comments/<%= comment.id %>/delete"
                        class="btn-icon-premium"
                        title="Hapus"
                        style="color: #ef4444;"
                        data-confirm-link
                        data-confirm-label="Hapus komentar"
                        data-confirm-title="Konfirmasi penghapusan"
                        data-confirm-message="Apakah Anda yakin untuk menghapus komentar ini?">
                        <i class="fas fa-trash-alt"></i>
                      </a>
                  </div>
                </div>
              </div>
              <% }) %>
                <% } else { %>
                  <div class="empty-state-premium">
                    <i class="fas fa-comment-slash"></i>
                    <p class="text-sm">Belum ada komentar</p>
                  </div>
                  <% } %>
        </div>
      </div>
    </div>

    <!-- Footer Note -->
    <div
      style="margin-top: 2rem; text-align: center; font-size: 0.7rem; color: #8aa3bc; border-top: 1px solid #e2ecf3; padding-top: 1.5rem;">
      <i class="fas fa-chart-simple"></i> Data diperbarui secara real-time · Panel Admin Modern
    </div>
  </div>
</body>

</html>
