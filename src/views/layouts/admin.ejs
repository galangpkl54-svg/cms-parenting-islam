<!DOCTYPE html>
<html lang="id" class="h-full">

<head>
  <% const siteTitle=typeof appName !=="undefined" ? appName : "CMS Blog" ; const pageTitle=typeof title !=="undefined"
    ? title : "Admin" ; const currentUser=typeof user !=="undefined" && user ? user : null; const
    userInitials=currentUser && currentUser.name ? currentUser.name.split(/\s+/).filter(Boolean).slice(0,
    2).map((part)=> part[0]).join("").toUpperCase() : "U";
    const csrf = typeof csrfToken !== "undefined" ? csrfToken : "";
    const isAuthPage = typeof authPage !== "undefined" && authPage;
    %>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="csrf-token" content="<%= csrf %>" />
    <title>
      <%= pageTitle ? `${pageTitle} | ${siteTitle}` : siteTitle %>
    </title>

    <!-- Google Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap"
      rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Custom Styles -->
    <link rel="stylesheet" href="/css/app.css" />

    <script>
      window.CMS_CSRF_TOKEN = "<%= csrf %>";
      window.CMS_INITIAL_NOTICES = <%- JSON.stringify((typeof notice !== "undefined" && notice) ? [{ type: typeof noticeType !== "undefined" && noticeType ? noticeType : "info", message: notice }] : []) %>;

      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ["Inter", "ui-sans-serif", "system-ui", "sans-serif"],
              mono: ["JetBrains Mono", "monospace"]
            },
            animation: {
              'fade-in': 'fadeIn 0.5s ease-out',
              'slide-up': 'slideUp 0.4s ease-out',
              'slide-down': 'slideDown 0.4s ease-out',
              'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
            },
            keyframes: {
              fadeIn: {
                '0%': { opacity: '0', transform: 'translateY(10px)' },
                '100%': { opacity: '1', transform: 'translateY(0)' },
              },
              slideUp: {
                '0%': { transform: 'translateY(10px)', opacity: '0' },
                '100%': { transform: 'translateY(0)', opacity: '1' },
              },
              slideDown: {
                '0%': { transform: 'translateY(-10px)', opacity: '0' },
                '100%': { transform: 'translateY(0)', opacity: '1' },
              },
            },
            colors: {
              brand: {
                50: "#eff6ff",
                100: "#dbeafe",
                200: "#bfdbfe",
                300: "#93c5fd",
                400: "#60a5fa",
                500: "#3b82f6",
                600: "#2271b1",
                700: "#135e96",
                800: "#0e4a73",
                900: "#0a3654"
              }
            }
          }
        }
      };
    </script>
    <script src="/js/app.js" defer></script>
    <style>
      /* Additional modern styles */
      .animate-fade-in {
        animation: fadeIn 0.5s ease-out;
      }

      /* Smooth transitions */
      .wp-nav-link,
      .wp-btn,
      .wp-panel,
      .wp-panel-strong {
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* Icon wrapper hover effect */
      .nav-icon-wrapper {
        transition: all 0.2s ease;
      }

      .wp-nav-link:hover .nav-icon-wrapper {
        transform: scale(1.05);
        background: linear-gradient(135deg, #2271b1, #135e96);
        color: white;
        box-shadow: 0 4px 12px rgba(34, 113, 177, 0.3);
      }

      .wp-nav-link-active .nav-icon-wrapper {
        background: linear-gradient(135deg, #2271b1, #135e96);
        color: white;
        box-shadow: 0 4px 12px rgba(34, 113, 177, 0.3);
      }

      /* Glass effect */
      .glass-enhanced {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.3);
      }

      /* Sidebar icon pulse animation */
      @keyframes iconPulse {

        0%,
        100% {
          transform: scale(1);
        }

        50% {
          transform: scale(1.05);
        }
      }

      .wp-nav-link-active .nav-icon-wrapper i {
        animation: iconPulse 0.3s ease;
      }

      .admin-sidebar .wp-nav-link {
        justify-content: flex-start;
      }

      @media (max-width: 1023px) {
        .admin-topbar-card {
          border-radius: 1.25rem;
        }
      }
    </style>
</head>

<body class="h-full overflow-x-hidden wp-shell bg-gradient-to-br from-slate-50 via-white to-slate-100 font-sans">
  <!-- Toast Container -->
  <div id="toastContainer" class="fixed top-4 right-4 z-50 flex flex-col gap-2"></div>

  <% if (isAuthPage) { %>
    <!-- Auth Pages (Login/Register) -->
    <div class="min-h-screen flex items-center justify-center p-4">
      <div class="w-full max-w-6xl animate-fade-in">
        <%- body %>
      </div>
    </div>
    <% } else { %>
      <!-- Admin Dashboard Layout -->
      <div class="flex min-h-screen">
        <button
          type="button"
          class="fixed left-4 top-4 z-50 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/95 px-4 py-2 text-sm font-semibold text-slate-700 shadow-lg backdrop-blur lg:hidden"
          data-admin-sidebar-open
          aria-controls="admin-sidebar"
          aria-expanded="false"
        >
          <i class="fas fa-bars"></i>
          Menu
        </button>

        <div class="fixed inset-0 z-40 hidden bg-slate-950/40 backdrop-blur-[1px] lg:hidden" data-admin-sidebar-overlay></div>

        <!-- SIDEBAR PREMIUM WITH ENHANCED ICONS -->
        <aside
          id="admin-sidebar"
          data-admin-sidebar
          class="admin-sidebar fixed inset-y-0 left-0 z-50 flex w-[88vw] max-w-xs -translate-x-full flex-col overflow-y-auto border-r border-slate-200/60 bg-white/95 px-5 py-6 shadow-2xl backdrop-blur-xl transition-transform duration-300 sm:w-80 lg:translate-x-0">

          <div class="mb-6 flex items-start justify-between gap-3 lg:mb-8">
            <!-- BRAND SECTION - Kotak Putih dengan Logo Biru -->
            <div class="flex-1 rounded-2xl bg-white p-5 shadow-lg ring-1 ring-slate-200/60">
            <div class="flex items-center gap-3">
              <!-- Logo Kotak Biru dengan Huruf C Putih -->
              <div
                class="flex h-16 w-16 items-center justify-center rounded-xl bg-gradient-to-br from-brand-600 to-brand-800 shadow-md"
                >
                <span class="text-4xl font-black tracking-tight text-white">C</span>
              </div>
              <div>
                <div class="text-[0.55rem] font-bold uppercase tracking-[0.25em] text-brand-600">
                  <%= siteTitle %>
                </div>
                <div class="text-base font-bold text-slate-800 mt-0.5">
                  Admin Panel
                </div>
              </div>
            </div>
            </div>

            <button
              type="button"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 shadow-sm lg:hidden"
              data-admin-sidebar-close
              aria-label="Tutup sidebar"
            >
              <i class="fas fa-xmark"></i>
            </button>
          </div>

          <!-- Navigation Menu dengan Icon Premium -->
          <nav class="flex-1 space-y-1.5">
            <p class="mb-3 px-3 text-[0.6rem] font-bold uppercase tracking-[0.2em] text-slate-400">
              <i class="fas fa-th-large mr-1 text-[0.5rem]"></i> MAIN MENU
            </p>

            <!-- Dashboard -->
            <a class="wp-nav-link flex items-center gap-3 rounded-xl px-3 py-2.5 transition-all duration-200 <%= typeof currentPath !== 'undefined' && currentPath === '/admin/dashboard' ? 'wp-nav-link-active bg-brand-50/80 ring-1 ring-brand-200' : 'hover:bg-slate-50' %>"
              href="/admin/dashboard">
              <div
                class="nav-icon-wrapper flex h-10 w-10 items-center justify-center rounded-xl bg-white text-brand-600 shadow-sm ring-1 ring-slate-200 transition-all duration-200">
                <i class="fas fa-chart-line text-lg"></i>
              </div>
              <div>
                <span class="font-semibold text-slate-700">Dashboard</span>
              </div>
            </a>

            <!-- Posts -->
            <a class="wp-nav-link flex items-center gap-3 rounded-xl px-3 py-2.5 transition-all duration-200 <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/posts') ? 'wp-nav-link-active bg-brand-50/80 ring-1 ring-brand-200' : 'hover:bg-slate-50' %>"
              href="/admin/posts">
              <div
                class="nav-icon-wrapper flex h-10 w-10 items-center justify-center rounded-xl bg-white text-emerald-600 shadow-sm ring-1 ring-slate-200 transition-all duration-200">
                <i class="fas fa-newspaper text-lg"></i>
              </div>
              <div>
                <span class="font-semibold text-slate-700">Posts</span>
              </div>
            </a>

            <!-- Categories -->
            <a class="wp-nav-link flex items-center gap-3 rounded-xl px-3 py-2.5 transition-all duration-200 <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/categories') ? 'wp-nav-link-active bg-brand-50/80 ring-1 ring-brand-200' : 'hover:bg-slate-50' %>"
              href="/admin/categories">
              <div
                class="nav-icon-wrapper flex h-10 w-10 items-center justify-center rounded-xl bg-white text-amber-600 shadow-sm ring-1 ring-slate-200 transition-all duration-200">
                <i class="fas fa-folder-tree text-lg"></i>
              </div>
              <div>
                <span class="font-semibold text-slate-700">Categories</span>
              </div>
            </a>

            <!-- Tags -->
            <a class="wp-nav-link flex items-center gap-3 rounded-xl px-3 py-2.5 transition-all duration-200 <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/tags') ? 'wp-nav-link-active bg-brand-50/80 ring-1 ring-brand-200' : 'hover:bg-slate-50' %>"
              href="/admin/tags">
              <div
                class="nav-icon-wrapper flex h-10 w-10 items-center justify-center rounded-xl bg-white text-cyan-600 shadow-sm ring-1 ring-slate-200 transition-all duration-200">
                <i class="fas fa-tags text-lg"></i>
              </div>
              <div>
                <span class="font-semibold text-slate-700">Tags</span>
              </div>
            </a>

            <!-- Media Library -->
            <a class="wp-nav-link flex items-center gap-3 rounded-xl px-3 py-2.5 transition-all duration-200 <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/media') ? 'wp-nav-link-active bg-brand-50/80 ring-1 ring-brand-200' : 'hover:bg-slate-50' %>"
              href="/admin/media">
              <div
                class="nav-icon-wrapper flex h-10 w-10 items-center justify-center rounded-xl bg-white text-purple-600 shadow-sm ring-1 ring-slate-200 transition-all duration-200">
                <i class="fas fa-images text-lg"></i>
              </div>
              <div>
                <span class="font-semibold text-slate-700">Media Library</span>
              </div>
            </a>

            <!-- Comments -->
            <a class="wp-nav-link flex items-center gap-3 rounded-xl px-3 py-2.5 transition-all duration-200 <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/comments') ? 'wp-nav-link-active bg-brand-50/80 ring-1 ring-brand-200' : 'hover:bg-slate-50' %>"
              href="/admin/comments">
              <div
                class="nav-icon-wrapper flex h-10 w-10 items-center justify-center rounded-xl bg-white text-rose-600 shadow-sm ring-1 ring-slate-200 transition-all duration-200">
                <i class="fas fa-comments text-lg"></i>
              </div>
              <div>
                <span class="font-semibold text-slate-700">Comments</span>
              </div>
            </a>

            <div class="my-4 border-t border-slate-200/60"></div>

            <p class="mb-3 px-3 text-[0.6rem] font-bold uppercase tracking-[0.2em] text-slate-400">
              <i class="fas fa-globe mr-1 text-[0.5rem]"></i> EXTERNAL
            </p>

            <!-- View Blog -->
            <a class="wp-nav-link flex items-center gap-3 rounded-xl px-3 py-2.5 transition-all duration-200 hover:bg-slate-50"
              href="/">
              <div
                class="nav-icon-wrapper flex h-10 w-10 items-center justify-center rounded-xl bg-white text-sky-600 shadow-sm ring-1 ring-slate-200 transition-all duration-200">
                <i class="fas fa-globe text-lg"></i>
              </div>
              <div>
                <span class="font-semibold text-slate-700">View Blog</span>
              </div>
            </a>
          </nav>

          <!-- User Profile Section Premium -->
          <div class="mt-auto pt-6">
            <div class="rounded-2xl bg-gradient-to-br from-slate-50 to-white p-4 shadow-md ring-1 ring-slate-200/50">
              <div class="flex items-center gap-3">
                <% if (currentUser && currentUser.avatar) { %>
                  <img src="<%= currentUser.avatar %>" alt="<%= currentUser.name %>"
                    class="h-14 w-14 rounded-xl object-cover border-2 border-brand-200 shadow-md" />
                  <% } else { %>
                    <div
                      class="flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-white font-bold text-xl shadow-md">
                      <%= userInitials %>
                    </div>
                    <% } %>
                      <div class="flex-1 min-w-0">
                        <div class="font-bold text-slate-800 truncate">
                          <%= currentUser ? currentUser.name : "Guest" %>
                        </div>
                        <div class="text-[0.65rem] text-slate-500 truncate">
                          <%= currentUser ? currentUser.email : "" %>
                        </div>
                        <div class="mt-1">
                          <span
                            class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-2 py-0.5 text-[0.55rem] font-semibold text-emerald-700">
                            <i class="fas fa-circle text-[0.25rem]"></i> Active
                          </span>
                        </div>
                      </div>
              </div>

              <div class="mt-4 space-y-2">
                <a href="/admin/profile"
                  class="flex w-full items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition-all hover:bg-slate-50 hover:shadow-sm">
                  <i class="fas fa-user-cog"></i> Profile Settings
                </a>

                <form action="/admin/logout" method="post">
                  <input type="hidden" name="_csrf" value="<%= csrf %>" />
                  <button type="submit"
                    class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-red-500 to-red-600 px-3 py-2 text-sm font-medium text-white transition-all hover:from-red-600 hover:to-red-700 hover:shadow-md">
                    <i class="fas fa-sign-out-alt"></i> Logout
                  </button>
                </form>
              </div>
            </div>
          </div>
        </aside>

        <!-- MAIN CONTENT AREA -->
        <div class="min-w-0 flex-1 lg:pl-80">
          <!-- HEADER MODERN -->
          <header class="sticky top-0 z-30 px-4 pt-16 sm:px-6 sm:pt-4 lg:px-8">
            <div class="admin-topbar-card relative overflow-hidden rounded-3xl border border-slate-200/70 bg-white/90 px-5 py-4 shadow-[0_16px_36px_rgba(15,23,42,0.08)] backdrop-blur-xl lg:px-7 lg:py-5">
              <div class="absolute inset-y-0 right-0 w-40 bg-gradient-to-l from-brand-100/70 to-transparent"></div>
              <div class="absolute -bottom-10 -left-10 h-28 w-28 rounded-full border border-brand-200/60 bg-brand-50/40"></div>
              <div class="relative flex items-start justify-between gap-4">
                <div class="space-y-1">
                  <p class="text-[0.62rem] font-semibold uppercase tracking-[0.28em] text-slate-500">
                    <i class="fas fa-shield-alt mr-1.5 text-brand-600"></i> SECURE ACCESS
                  </p>
                  <h1 class="text-2xl font-bold tracking-tight text-slate-800 lg:text-[2rem]">
                    <%= pageTitle || "Dashboard" %>
                  </h1>
                </div>
              </div>
            </div>
          </header>

          <!-- PAGE CONTENT -->
          <main class="animate-fade-in p-4 sm:p-6 lg:p-8">
            <%- body %>
          </main>
        </div>
      </div>
      <% } %>

        <script>
          // Toast Notifications
          (function () {
            const notices = window.CMS_INITIAL_NOTICES || [];
            const toastContainer = document.getElementById('toastContainer');

            function showToast(message, type = 'info') {
              if (!toastContainer) return;

              const colors = {
                success: 'bg-emerald-500',
                error: 'bg-red-500',
                warning: 'bg-amber-500',
                info: 'bg-blue-500'
              };

              const icons = {
                success: 'fa-check-circle',
                error: 'fa-exclamation-circle',
                warning: 'fa-exclamation-triangle',
                info: 'fa-info-circle'
              };

              const toast = document.createElement('div');
              toast.className = `flex items-center gap-3 rounded-xl ${colors[type] || colors.info} px-4 py-3 text-white shadow-lg animate-slide-up`;
              toast.innerHTML = `
          <i class="fas ${icons[type] || icons.info}"></i>
          <span class="text-sm font-medium flex-1">${escapeHtml(message)}</span>
          <button class="text-white/80 hover:text-white transition" onclick="this.parentElement.remove()">
            <i class="fas fa-times"></i>
          </button>
        `;

              toastContainer.appendChild(toast);
              setTimeout(() => {
                if (toast.parentElement) toast.remove();
              }, 5000);
            }

            function escapeHtml(text) {
              const div = document.createElement('div');
              div.textContent = text;
              return div.innerHTML;
            }

            notices.forEach(notice => showToast(notice.message, notice.type));
          })();

          (function () {
            const sidebar = document.querySelector("[data-admin-sidebar]");
            const overlay = document.querySelector("[data-admin-sidebar-overlay]");
            const openButtons = Array.from(document.querySelectorAll("[data-admin-sidebar-open]"));
            const closeButtons = Array.from(document.querySelectorAll("[data-admin-sidebar-close]"));
            const mobileQuery = window.matchMedia("(max-width: 1023px)");

            if (!(sidebar instanceof HTMLElement) || !(overlay instanceof HTMLElement)) {
              return;
            }

            const setExpanded = (expanded) => {
              openButtons.forEach((button) => {
                if (button instanceof HTMLButtonElement) {
                  button.setAttribute("aria-expanded", expanded ? "true" : "false");
                }
              });
            };

            const openSidebar = () => {
              sidebar.classList.remove("-translate-x-full");
              sidebar.classList.add("translate-x-0");
              overlay.classList.remove("hidden");
              document.body.classList.add("overflow-hidden");
              setExpanded(true);
            };

            const closeSidebar = () => {
              sidebar.classList.add("-translate-x-full");
              sidebar.classList.remove("translate-x-0");
              overlay.classList.add("hidden");
              document.body.classList.remove("overflow-hidden");
              setExpanded(false);
            };

            openButtons.forEach((button) => {
              if (button instanceof HTMLButtonElement) {
                button.addEventListener("click", () => {
                  if (sidebar.classList.contains("-translate-x-full")) {
                    openSidebar();
                  } else {
                    closeSidebar();
                  }
                });
              }
            });

            closeButtons.forEach((button) => {
              if (button instanceof HTMLButtonElement) {
                button.addEventListener("click", closeSidebar);
              }
            });

            overlay.addEventListener("click", closeSidebar);

            sidebar.querySelectorAll("a").forEach((link) => {
              link.addEventListener("click", () => {
                if (mobileQuery.matches) {
                  closeSidebar();
                }
              });
            });

            const syncSidebar = () => {
              if (mobileQuery.matches) {
                sidebar.classList.add("-translate-x-full");
                sidebar.classList.remove("translate-x-0");
                overlay.classList.add("hidden");
                document.body.classList.remove("overflow-hidden");
                setExpanded(false);
                return;
              }

              sidebar.classList.remove("-translate-x-full");
              sidebar.classList.add("translate-x-0");
              overlay.classList.add("hidden");
              document.body.classList.remove("overflow-hidden");
              setExpanded(false);
            };

            mobileQuery.addEventListener("change", syncSidebar);
            syncSidebar();
          })();
        </script>
</body>

</html>
