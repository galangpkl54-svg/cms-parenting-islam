{
  "name": "cms-blog-laragon",
  "version": "1.0.0",
  "private": true,
  "description": "Modern CMS Blog with Node.js, Express, TypeScript, MySQL, Prisma, EJS, Tailwind, JWT, Multer, Sharp, and Zod",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "npm run build && node dist/src/server.js",
    "dev:watch": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs');fs.copyFileSync('src/public/js/app.js','public/js/app.js');fs.copyFileSync('src/public/css/app.css','public/css/app.css');\"",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.cjs",
    "copy:tinymce": "xcopy node_modules\\tinymce public\\vendor\\tinymce /E /I /Y",
    "tailwind:build": "tailwindcss -i ./public/css/app.css -o ./public/css/output.css --minify",
    "tailwind:watch": "tailwindcss -i ./public/css/app.css -o ./public/css/output.css --watch"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "multer": "^1.4.5-lts.2",
    "prisma": "^6.9.0",
    "sanitize-html": "^2.16.0",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "tinymce": "^8.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/method-override": "^0.0.34",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
